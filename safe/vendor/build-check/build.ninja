# This is the build file for project "glib"
# It is autogenerated by the Meson build system.
# Do not edit by hand.

ninja_required_version = 1.8.2

# Rules for module scanning.

# Rules for compiling.

rule c_COMPILER
 command = cc $ARGS -MD -MQ $out -MF $DEPFILE -o $out -c $in
 deps = gcc
 depfile = $DEPFILE_UNQUOTED
 description = Compiling C object $out

rule cpp_COMPILER
 command = c++ $ARGS -MD -MQ $out -MF $DEPFILE -o $out -c $in
 deps = gcc
 depfile = $DEPFILE_UNQUOTED
 description = Compiling C++ object $out

# Rules for linking.

rule STATIC_LINKER
 command = rm -f $out && gcc-ar $LINK_ARGS $out $in
 description = Linking static target $out

rule c_LINKER
 command = cc $ARGS -o $out $in $LINK_ARGS
 description = Linking target $out

rule cpp_LINKER
 command = c++ $ARGS -o $out $in $LINK_ARGS
 description = Linking target $out

rule SHSYM
 command = /home/yans/.local/bin/meson --internal symbolextractor /home/yans/safelibs/port-glib/build-check $in $IMPLIB $out $CROSS
 description = Generating symbol file $out
 restat = 1

# Other rules

rule CUSTOM_COMMAND
 command = $COMMAND
 description = $DESC
 restat = 1

rule REGENERATE_BUILD
 command = /home/yans/.local/bin/meson --internal regenerate /home/yans/safelibs/port-glib/original .
 description = Regenerating build files
 generator = 1

# Phony build target, always out of date

build PHONY: phony 

# Build rules for targets

build glib/gversionmacros.h: CUSTOM_COMMAND ../original/glib/gversionmacros.h.in | /home/yans/safelibs/port-glib/original/tools/gen-visibility-macros.py
 COMMAND = /home/yans/safelibs/port-glib/original/tools/gen-visibility-macros.py 2.80.0 versions-macros ../original/glib/gversionmacros.h.in glib/gversionmacros.h
 description = Generating$ glib/gversionmacros.h$ with$ a$ custom$ command

build glib/glib-visibility.h: CUSTOM_COMMAND  | /home/yans/safelibs/port-glib/original/tools/gen-visibility-macros.py
 COMMAND = /home/yans/safelibs/port-glib/original/tools/gen-visibility-macros.py 2.80.0 visibility-macros GLIB glib/glib-visibility.h
 description = Generating$ glib/glib-visibility.h$ with$ a$ custom$ command

