prefix=/home/yans/safelibs/port-glib/build-check
includedir=${prefix}/include
libdir=${prefix}/lib/x86_64-linux-gnu
srcdir=/home/yans/safelibs/port-glib/original

Name: GThread
Description: Thread support for GLib
Version: 2.80.0
Requires: glib-2.0
Libs: -L${prefix}/gthread -lgthread-2.0 -pthread
Cflags: -I${prefix} -I${srcdir} -I${prefix}/glib -I${srcdir}/glib -I${prefix}/gthread -I${srcdir}/gthread -pthread
