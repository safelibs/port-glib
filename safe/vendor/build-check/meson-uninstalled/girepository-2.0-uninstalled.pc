prefix=/home/yans/safelibs/port-glib/build-check
includedir=${prefix}/include
libdir=${prefix}/lib/x86_64-linux-gnu
srcdir=/home/yans/safelibs/port-glib/original

Name: girepository
Description: GObject Introspection repository parser
Version: 2.80.0
Requires: glib-2.0, gobject-2.0
Requires.private: gmodule-no-export-2.0, gio-2.0, libffi >=  3.0.0
Libs: -L${prefix}/girepository -lgirepository-2.0
Libs.private: -lm
Cflags: -I${prefix} -I${srcdir} -I${prefix}/girepository -I${srcdir}/girepository -I${prefix}/glib -I${srcdir}/glib -I${prefix}/gobject -I${srcdir}/gobject -I${prefix}/gmodule -I${srcdir}/gmodule -I${prefix}/gio -I${srcdir}/gio
