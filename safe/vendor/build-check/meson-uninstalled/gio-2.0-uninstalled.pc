prefix=/home/yans/safelibs/port-glib/build-check
includedir=${prefix}/include
libdir=${prefix}/lib/x86_64-linux-gnu
srcdir=/home/yans/safelibs/port-glib/original

Name: GIO
Description: glib I/O library
Version: 2.80.0
Requires: glib-2.0, gobject-2.0
Requires.private: gmodule-no-export-2.0, zlib, mount >= 2.23, libselinux >= 2.2
Libs: -L${prefix}/gio -lgio-2.0
Cflags: -I${prefix} -I${srcdir} -I${prefix}/gio -I${srcdir}/gio -I${prefix}/glib -I${srcdir}/glib -I${prefix}/gobject -I${srcdir}/gobject -I${prefix}/gmodule -I${srcdir}/gmodule -I${prefix}/subprojects/gvdb -I${srcdir}/subprojects/gvdb
